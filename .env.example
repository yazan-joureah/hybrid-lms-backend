# ── Application ──────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
PORT=3000

# ── MongoDB ──────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/hybrid_lms

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────────
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# ── Argon2id (NIST SP 800-63-4) ──────────────────────────────
ARGON2_MEMORY_KB=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=1

# ── Rate Limiting (Android-style exponential backoff) ────────
RATE_LIMIT_WINDOW_MS=600000
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_BASE_LOCKOUT_SECONDS=30
RATE_LIMIT_MAX_LOCKOUT_SECONDS=1800

# ── Gmail (OAuth2 — gmail.send scope only) ───────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=