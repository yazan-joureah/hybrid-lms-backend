        {
          "name": "Rate Limiting (Android-style backoff)",
          "item": [
            {
              "name": "Register — repeat this request 6x via Collection Runner to trigger 429",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "// On the 6th+ run within the window, this assertion is what should pass.",
                      "// On runs 1-5 it will correctly show as a 'failed' assertion — that is expected,",
                      "// not a bug. See README section 'Rate limiting test interpretation'.",
                      "if (pm.response.code === 429) {",
                      "  pm.test('429 body has error.code=RATE_LIMITED', () => {",
                      "    pm.expect(pm.response.json().error.code).to.eql('RATE_LIMITED');",
                      "  });",
                      "  pm.test('Retry-After header is a positive integer', () => {",
                      "    const retryAfter = Number(pm.response.headers.get('Retry-After'));",
                      "    pm.expect(retryAfter).to.be.above(0);",
                      "  });",
                      "} else {",
                      "  pm.test('below threshold — 201 as expected', () => pm.response.to.have.status(201));",
                      "}"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"full_name\": \"Rate Limit Target\",\n  \"email\": \"rate.limit.target@example.com\",\n  \"password\": \"{{randomPassword}}\",\n  \"birth_date\": \"{{adultBirthDate}}\",\n  \"role\": \"Student\",\n  \"privacy_consent_version\": \"v1.0\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
                "description": "IMPORTANT: uses a FIXED email (not the dynamic {{randomEmail}}) on purpose — the rate limiter keys off the identifier, so repeating this exact request is what accumulates hits. Run via Collection Runner with 6+ iterations, or Newman with -n 6. Because the backoff is escalating and persists 24h (violationsTtlSeconds), flush Redis between full test-suite runs — see README."
              }
            }
          ]
        }
      ]
