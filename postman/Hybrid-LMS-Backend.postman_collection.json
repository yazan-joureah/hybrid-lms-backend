                      "pm.test('requires_guardian_approval is NOT present for an adult', () => {",
                      "  pm.expect(body.data.requires_guardian_approval).to.be.undefined;",
                      "});",
                      "pm.test('CSP security header is present (Helmet)', () => {",
                      "  pm.expect(pm.response.headers.has('Content-Security-Policy')).to.be.true;",
                      "});"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
