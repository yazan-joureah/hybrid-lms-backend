              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 401', () => pm.response.to.have.status(401));",
                  "pm.test('error.code is INVALID_CREDENTIALS', () => {",
                  "  pm.expect(pm.response.json().error.code).to.eql('INVALID_CREDENTIALS');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"this.account.does.not.exist@example.com\",\n  \"password\": \"{{seededPassword}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "description": "Run this AND a request with a real email + wrong password, then diff the two bodies by hand once — they must be byte-identical (see tests/integration/login.test.js for the automated version of this exact check)."
          }
        }
      ]
