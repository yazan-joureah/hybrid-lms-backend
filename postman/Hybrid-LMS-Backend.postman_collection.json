{
  "info": {
    "_postman_id": "d4e5f6a7-0000-4000-8000-000000000000",
    "name": "Hybrid LMS Backend — AUTH Module",
    "description": "Curated, representative Postman test suite for the AUTH module of the Hybrid LMS backend (Yazan Jawriyyeh — 174681). Covers every endpoint actually implemented as of this collection's creation date: Health Check, Registration, Email Verification, Guardian Approval, and Login. Requests marked [MANUAL] in their description require a value copied by a human from the running server's console (dev-mode email log) or a real inbox, because raw verification/approval tokens are, by design (DP-08), never returned in any API response. See README.md in this folder for full setup and CI/CD notes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Collection-wide utility: a fresh unique email + matching NFR-01-compliant",
          "// password for every request that needs brand-new, never-seen-before test data.",
          "const ts = Date.now();",
          "pm.collectionVariables.set('timestamp', ts);",
          "pm.collectionVariables.set('randomEmail', `postman.dynamic.${ts}@example.com`);",
          "pm.collectionVariables.set('randomPassword', `Postman-Dynamic-Passphrase-${ts}`);",
          "",
          "function isoDateYearsAgo(years, extraDays = 0) {",
          "  const d = new Date();",
          "  d.setFullYear(d.getFullYear() - years);",
          "  d.setDate(d.getDate() - extraDays);",
          "  return d.toISOString().split('T')[0];",
          "}",
          "pm.collectionVariables.set('adultBirthDate', isoDateYearsAgo(30));",
          "pm.collectionVariables.set('exactly18BirthDate', isoDateYearsAgo(18));",
          "pm.collectionVariables.set('minorBirthDate', isoDateYearsAgo(17, 364));"
        ]
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" }
  ],
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "GET /health — service is up",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('success is true', () => pm.expect(body.success).to.eql(true));",
                  "pm.test('data.status is ok', () => pm.expect(body.data.status).to.eql('ok'));",
                  "pm.test('data.timestamp is a valid ISO date', () => {",
                  "  pm.expect(new Date(body.data.timestamp).toISOString()).to.eql(body.data.timestamp);",
                  "});",
                  "pm.test('Content-Type is application/json', () => {",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] },
            "description": "Liveness check only — does NOT verify DB/Redis connectivity. See README for why this matters when interpreting a green result."
          }
        }
      ]
    },
