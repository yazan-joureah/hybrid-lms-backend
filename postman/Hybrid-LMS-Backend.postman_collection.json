                  "    pm.expect(['active', 'guardian_pending']).to.include(pm.response.json().data.status);",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/verify-email?token={{manualVerificationToken}}",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "verify-email"],
              "query": [{ "key": "token", "value": "{{manualVerificationToken}}" }]
            },
            "description": "MANUAL STEP REQUIRED: run 'Register — Adult Student' above first, then copy the token from the '--- DEV EMAIL ---' block printed in the server's terminal (or the real inbox if Gmail is configured), paste it into the 'manualVerificationToken' environment variable, then run this request. This cannot be automated in Newman/CI without a dedicated test-only endpoint — see README."
          }
        }
      ]
