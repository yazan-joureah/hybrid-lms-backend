    {
      "name": "Authentication — Login",
      "item": [
        {
          "name": "Login — Success (no MFA, seeded user)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('access_token is present', () => pm.expect(body.data.access_token).to.be.a('string'));",
                  "pm.test('redirect_to is /dashboard for a Student', () => {",
                  "  pm.expect(body.data.user.redirect_to).to.eql('/dashboard');",
                  "});",
                  "pm.test('refresh_token cookie is set as HttpOnly', () => {",
                  "  const setCookie = pm.response.headers.get('Set-Cookie') || '';",
                  "  pm.expect(setCookie).to.include('refresh_token=');",
                  "  pm.expect(setCookie).to.include('HttpOnly');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{seededLoginEmail}}\",\n  \"password\": \"{{seededPassword}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "description": "REQUIRES running scripts/seedTestUser.js once against your local database first — see README."
          }
        },
        {
          "name": "Login — MFA required (seeded MFA user)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('mfa_required is true', () => pm.expect(body.data.mfa_required).to.eql(true));",
                  "pm.test('mfa_temp_token is present, access_token is NOT', () => {",
                  "  pm.expect(body.data.mfa_temp_token).to.be.a('string');",
                  "  pm.expect(body.data.access_token).to.be.undefined;",
                  "});",
                  "pm.test('no refresh_token cookie is set before MFA is proven', () => {",
                  "  pm.expect(pm.response.headers.has('Set-Cookie')).to.be.false;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{seededMfaEmail}}\",\n  \"password\": \"{{seededPassword}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
